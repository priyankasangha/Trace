generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User { 
  id          Int           @id @default(autoincrement())
  name        String
  email       String        @unique
  profilePic  String?       // URL for profile picture
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  appleUserId String? @unique

  journeys    Participant[] // Relationships to journeys this user can see and edit
  feedbacks   Feedback[]
}

model Journey {
  id           Int           @id @default(autoincrement())
  title        String
  description  String?
  coverPage    String?
  completed    Boolean       @default(false)

  // Add these:
  startYear    Int?
  startMonth   Int?
  startDay     Int?
  endYear      Int?
  endMonth     Int?
  endDay       Int?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  events       Event[]
  participants Participant[]
}

model Participant {
  userId    Int
  journeyId Int
  
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  journey   Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@id([userId, journeyId]) // Composite ID ensures a user is linked to a journey exactly once
  @@index([journeyId])
}

model Event {
  id                 Int      @id @default(autoincrement())
  title              String
  description        String?
  
  // Date Fields (Splitting lets you map exact points on a chronological timeline graph)
  year               Int
  month              Int?     
  day                Int?     
  
  // Native macOS MapKit Fields
  locationName       String?  // e.g., "The Colosseum" or "Central Park"
  latitude           Float?   // e.g., 41.8902
  longitude          Float?   // e.g., 12.4922
  
  coverImage         String?  // Flagship image per event milestone
  albumImages        String[] // Array containing all paths/URLs for photo carousel/grid arrays
  journal            String?  // Text area for long-form thoughts
  
  // Per-Event Anniversary Confetti Trackers
  anniversaryEnabled Boolean  @default(false) // User can toggle this on or off in the UI
  lastCelebratedYear Int?     // Tracks the last year the confetti popped for this specific event

  // Dual-View Filter Toggle
  isVisibleInHighlights Boolean @default(true) // Controls if it shows up in the "Select Events" view

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  journeyId          Int
  journey            Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
}

model Feedback {
  id        Int      @id @default(autoincrement())
  content   String   // The actual feedback message
  urgency    Int     // 1-5
  resolved  Boolean  @default(false) // So you can track if you've read/fixed it!
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tracks who left the feedback
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}