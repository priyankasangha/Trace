// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User { 
  id Int @id @default(autoincrement())
  name String
  email String @unique
  profilePic String? // url profile pic

  journeys Participant[] // one user can be the journey user in many journeys
  friendships Friendship[] @relation("UserFriendships") // friends this user added
  friendsOf Friendship[] @relation("FriendOf") // friends who added this user
  favourites Journey[] @relation("UserFavourites")
}

model Journey {
  id Int @id @default(autoincrement())
  title String
  startYear Int
  visibility JourneyVisibility @default(PRIVATE) // could be public or private

  events Event[]
  participants Participant[]

  favouritedBy User[] @relation("UserFavourites")
}

model Participant {
  userId Int
  journeyId Int
  
  user User @relation(fields: [userId], references: [id])
  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  role JourneyRole //  owner/viewer

  @@id([userId, journeyId]) // composite id
  @@index([journeyId])
}

enum JourneyVisibility {
  PUBLIC
  PRIVATE
}

enum JourneyRole {
  PRIMARY_OWNER
  CO_OWNER
  VIEWER
}

model Event {
  id Int @id @default(autoincrement())
  title String
  description String?
  year Int
  month Int?
  day Int?
  country String?
  city String?
  place String?
  imageUrls String[]
  hiddenFromMe Boolean @default(false)
  hiddenFromOthers Boolean @default(false)
  anniversaryEnabled Boolean @default(false)
  reminderEnabled Boolean @default(false)

  journey Journey @relation(fields: [journeyId], references: [id])
  journeyId Int
  tags EventTag[]
}

model Tag {
  id Int @id @default(autoincrement())
  name String @unique
  events EventTag[]
}

model EventTag {
  eventId Int
  tagId Int

  event Event @relation(fields: [eventId], references: [id])
  tag   Tag   @relation(fields: [tagId], references: [id])


  @@id([eventId, tagId]) // composite PK
  @@index([tagId]) // to speed up queries
}

// mutual friendship model
model Friendship {
  id Int @id @default(autoincrement())

  userId Int
  friendId Int

  user User @relation("UserFriendships", fields: [userId], references: [id])
  friend User @relation("FriendOf", fields: [friendId], references: [id])

  status FriendshipStatus @default(NONE) // pending, accepted, blocked, NONE

  @@index([friendId, status]) // composite for make status easy to lookup
  @@unique([userId, friendId]) // no duplicate friendships
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
  NONE
}
