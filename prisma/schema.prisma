// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User { 
  id Int @id @default(autoincrement())
  name String
  email String @unique
  journeys JourneyUser[] // one user can be the journey user in many journeys
}

model Journey {
  id Int @id @default(autoincrement())
  title String
  startYear Int
  events Event[]
  user JourneyUser[]
}

model JourneyUser {
  userId Int
  journeyId Int
  
  user User @relation(fields: [userId], references: [id])
  journey Journey @relation(fields: [journeyId], references: [id])

   role String //  owner, collaborator, viewer

   @@id([userId, journeyId]) // composite id
   @@index([journeyId])
}

model Event {
  id Int @id @default(autoincrement())
  title String
  description String?
  year Int
  month Int?
  day Int?
  country String?
  city String?
  place String?
  imageUrls String[]?

  journey Journey @relation(fields: [journeyId], references: [id])
  journeyId Int
  tags EventTag[]?
}

model Tag {
  id Int @id @default(autoincrement())
  name String @unique
  events EventTag[]
}

model EventTag {
  eventId Int
  tagId Int

  event Event @relation(fields: [eventId], references: [id])
  tag   Tag   @relation(fields: [tagId], references: [id])


  @@id([eventId, tagId]) // composite PK
  @@index([tagId]) // to speed up queries
}
